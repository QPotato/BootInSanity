[Unit]
Description=BootInSanity Installer (runs when install= in kernel cmdline)
After=systemd-udev-settle.service local-fs.target
Before=getty@tty1.service
Wants=systemd-udev-settle.service
ConditionKernelCommandLine=install

[Service]
Type=oneshot
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
ExecStart=/opt/bootinsanity-installer/install.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
