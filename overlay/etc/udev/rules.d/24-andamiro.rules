# Andamiro PIUIO (0547:1002) — raw USB access for XSanity (libusb).
# usbhid is told to ignore this device via modprobe quirks; libusb opens it.
SUBSYSTEMS=="usb", ATTRS{idVendor}=="0547", ATTRS{idProduct}=="1002", OWNER="pump", GROUP="pump", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0547", ATTRS{idProduct}=="1002", OWNER="pump", GROUP="pump", MODE="0660"

# Andamiro LXIO (0d2f:1020, 0d2f:1040)
SUBSYSTEMS=="usb", ATTRS{idVendor}=="0d2f", ATTRS{idProduct}=="1020", OWNER="pump", GROUP="pump", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0d2f", ATTRS{idProduct}=="1020", OWNER="pump", GROUP="pump", MODE="0660"

SUBSYSTEMS=="usb", ATTRS{idVendor}=="0d2f", ATTRS{idProduct}=="1040", OWNER="pump", GROUP="pump", MODE="0660"
KERNEL=="hidraw*", ATTRS{idVendor}=="0d2f", ATTRS{idProduct}=="1040", OWNER="pump", GROUP="pump", MODE="0660"
