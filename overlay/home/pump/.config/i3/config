# i3 config file (v4)
# BootInSanity kiosk config — XSanity fullscreen with system-mode escape hatch.

set $mod Mod4

font pango:monospace 8

# Kiosk: no borders, no bars.
default_border        none
default_floating_border none
hide_edge_borders     both

# No status bar.
# (i3bar deliberately omitted.)

# Autostart XSanity launcher.
exec --no-startup-id /opt/bootinsanity/launch.sh

# ---------------------------------------------------------------------------
# System mode — Win+F4 drops to desktop (kills XSanity crash-loop).
# ---------------------------------------------------------------------------
bindsym $mod+F4      exec --no-startup-id /opt/bootinsanity/system-mode/exit-to-desktop.sh

# ---------------------------------------------------------------------------
# Win+key shortcuts (available in system mode and kiosk mode).
# ---------------------------------------------------------------------------
bindsym $mod+Return  exec --no-startup-id lxterminal
bindsym $mod+m       exec --no-startup-id /opt/bootinsanity/system-mode/configure-memcards.sh
bindsym $mod+r       exec --no-startup-id /opt/bootinsanity/system-mode/reset-xsanity.sh
bindsym $mod+v       exec --no-startup-id /opt/bootinsanity/system-mode/volume-mixer.sh
bindsym $mod+e       exec --no-startup-id /opt/bootinsanity/system-mode/polling-rate.sh
bindsym $mod+x       exec --no-startup-id /opt/bootinsanity/system-mode/expand-p3.sh
bindsym $mod+b       exec --no-startup-id systemctl reboot
bindsym $mod+p       exec --no-startup-id systemctl poweroff
